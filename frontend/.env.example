# ============================================================
# New_Vacancy (NV) — Environment Variables
# ============================================================
# IMPORTANT: Copy this file to .env and fill in your real values
# NEVER commit .env to Git (it's already in .gitignore)
# ============================================================
# For Vercel: Add these in Project → Settings → Environment Variables

# ── Supabase ─────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── OpenAI (REQUIRED for AI Resume Analysis) ──────────────────
# Get your API key from: https://platform.openai.com/api-keys
# Used for: Resume matching, ATS scoring, career insights
VITE_OPENAI_API_KEY=your-openai-api-key-here

# ── App ───────────────────────────────────────────────────────
VITE_APP_NAME=New_vacancy
VITE_APP_URL=https://your-vercel-domain.vercel.app
