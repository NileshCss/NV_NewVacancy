PORT=5000
NODE_ENV=production

# ── AI Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# Groq API Key — used by Job URL Auto-Fill (free tier: https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxx
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxx

# ── Auth ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_jwt_secret_minimum_32_characters_long_change_in_production
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your deployed Vercel frontend URL
FRONTEND_URL=https://www.newvacancy.live

MAX_FILE_SIZE_MB=5
RATE_LIMIT_ANALYSES_PER_HOUR=10

# ── WhatsApp Configuration (Baileys — no headless browser needed) ───────────
# Set WHATSAPP_ENABLED=true to activate the WhatsApp notification service.
# On first boot the server will print a QR code — scan it with WhatsApp.
WHATSAPP_ENABLED=false

# WhatsApp Group JID — format: 120363XXXXXXXXXX@g.us
# Run the server once, scan QR, then use /api/whatsapp/chats to discover the JID.
WHATSAPP_GROUP_ID=120363XXXXXXXXXX@g.us

# WhatsApp Channel/Newsletter JID — format: 120363XXXXXXXXXX@newsletter
# Find via: GET /api/whatsapp/chats (look for isReadOnly:true, isGroup:false entries)
WHATSAPP_CHANNEL_ID=

# Auto-reconnect on disconnect (default: true)
WHATSAPP_AUTO_RECONNECT=true

# Max messages sent per hour before queuing (default: 20)
MAX_MESSAGES_PER_HOUR=20

# Path where Baileys session data is stored — add to .gitignore, never commit!
WHATSAPP_AUTH_PATH=./.baileys_auth_info

# ── Ollama (Local AI) ────────────────────────────────────────────────────────
# Set AI_PROVIDER=groq for cloud deployment (no Ollama server needed)
# Set AI_PROVIDER=auto to try Ollama first, fall back to Groq
# Set AI_PROVIDER=ollama to force Ollama (requires Ollama server running locally)
AI_PROVIDER=groq
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=60000

# ── Telegram Notifications ───────────────────────────────────────────────────
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Channel: @channelname or numeric chat_id (-100xxxxxxxxxx for channels)
TELEGRAM_CHANNEL_ID=

# ── Email Digest (Nodemailer + Gmail SMTP) ───────────────────────────────────
# Use Gmail App Password (NOT your account password):
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=NewVacancy <noreply@newvacancy.live>

# ── Scraper Configuration ────────────────────────────────────────────────────
SCRAPER_ENABLED=true
SCRAPER_MAX_JOBS_PER_RUN=50
SCRAPER_RESPECT_ROBOTS=true
# Cron schedule for scraper (default: 5 minutes past every hour)
SCRAPER_CRON=5 * * * *
# Daily expire cron (default: 2:00 AM IST)
EXPIRE_JOBS_CRON=30 20 * * *
# Daily digest cron (default: 8:00 AM IST)
DAILY_DIGEST_CRON=30 2 * * *
# Weekly digest cron (default: Monday 9:00 AM IST)
WEEKLY_DIGEST_CRON=30 3 * * 1

# ── Site Configuration ───────────────────────────────────────────────────────
SITE_URL=https://www.newvacancy.live
